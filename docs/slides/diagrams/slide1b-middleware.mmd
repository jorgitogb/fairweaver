    classDef search fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    classDef out fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px,color:#4a148c

    class DH hub
    class MW mw
    class SH search
    class B out
